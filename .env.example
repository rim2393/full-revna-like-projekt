# Core deployment configuration
PANEL_DOMAIN=panel.example.com
SUBSCRIPTION_DOMAIN=sub.example.com
ACME_EMAIL=security@example.com
TZ=UTC
AUTH_PORTAL_DOMAIN=
LUMEN_HOME=/opt/lumen
LUMEN_DATA_DIR=/opt/lumen/data
LUMEN_BACKUP_DIR=/opt/lumen/backups
LUMEN_SUPPORT_DIR=/opt/lumen/support-bundles
LUMEN_SECRETS_DIR=/opt/lumen/secrets
TLS_CERT_DIR=/etc/nginx/lumen/certs
LUMEN_API_PORT=8080
LUMEN_WEB_PORT=3000
LUMEN_SUBSCRIPTION_PORT=8081

# Installer / registry settings
REGISTRY_HOST=ghcr.io
REGISTRY_USERNAME=
REGISTRY_TOKEN_FILE=
# Admin bootstrap
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=GENERATE

# Required secrets
POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME
REFRESH_SECRET=CHANGE_ME
API_TOKEN_PEPPER=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME
WEBHOOK_SIGNING_SECRET=CHANGE_ME
NODE_CA_SEED=CHANGE_ME
MANIFEST_SIGNING_SEED=CHANGE_ME
RECOVERY_KEY=CHANGE_ME

# Optional filesystem-backed secret overrides
DATABASE_URL_FILE=/run/lumen/secrets/database-url
REDIS_URL_FILE=/run/lumen/secrets/redis-url
JWT_SECRET_FILE=/run/lumen/secrets/jwt-secret
REFRESH_SECRET_FILE=/run/lumen/secrets/refresh-secret
API_TOKEN_PEPPER_FILE=/run/lumen/secrets/api-token-pepper
ENCRYPTION_KEY_FILE=/run/lumen/secrets/encryption-key
WEBHOOK_SIGNING_SECRET_FILE=/run/lumen/secrets/webhook-signing-secret
POSTGRES_PASSWORD_FILE=/run/lumen/secrets/postgres-password
REDIS_PASSWORD_FILE=/run/lumen/secrets/redis-password

# Compatibility values for legacy image readers
DATABASE_URL=postgresql://lumen:${POSTGRES_PASSWORD}@postgres:5432/lumen
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Image references
POSTGRES_IMAGE=postgres:17.6@sha256:00bc86618629af00d2937fdc5a5d63db3ff8450acf52f0636ec813c7f4902929
REDIS_IMAGE=valkey/valkey:9-alpine@sha256:a35428eba9043cc0b79dbe54100f0c92784f2de00ad09b01182bfb1c5c83d1bd
LUMEN_API_IMAGE=ghcr.io/rim2393/lumen-api:v0.1.0@sha256:cbebe2b643c4ee514e853303c28331c0ac6f08ae213547a63710f09fe729bf00
LUMEN_WEB_IMAGE=ghcr.io/rim2393/lumen-web:v0.1.0@sha256:b7a3408884046bf92e106cffff6de8695bf3b4b48bc62a204a3a902b9a690032
LUMEN_NODE_AGENT_IMAGE=ghcr.io/rim2393/lumen-node-agent:v0.1.0@sha256:1782c3a44d92868b2ec7dd00ae38d044a5b446936ce5ff0c20303d7498161909
LUMEN_SUBSCRIPTION_IMAGE=ghcr.io/rim2393/lumen-subscription-page:v0.1.0@sha256:5d8ba5e0f3bea2fa9d6bea597acf993b6b0561e5adc52ce032227fd0d8c57bcf

# acme.sh installation verification
ACME_SH_INSTALL_URL=https://get.acme.sh
ACME_SH_INSTALL_SHA256=CHANGE_ME

# Safety defaults
LUMEN_VERSION=unknown
